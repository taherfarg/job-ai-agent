# ─── Job Search Settings ───────────────────────────────────────────────────────
JOB_KEYWORD=AI Engineer
JOB_LOCATION=Remote
MIN_MATCH_SCORE=80
MAX_APPLICATIONS_PER_DAY=20

# ─── LLM Settings ──────────────────────────────────────────────────────────────
LLM_MODEL=llama3:latest
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Applicant Contact Info (used by Playwright automation) ────────────────────
APPLICANT_EMAIL=your_email@example.com
APPLICANT_PHONE=+1234567890

# ─── Scraping Settings ─────────────────────────────────────────────────────────
SCRAPE_LIMIT=15
SCRAPE_RETRIES=3
